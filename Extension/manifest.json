{
    "manifest_version": 3,
    "name": "Dep trai. vi en",
    "version": "36.18.36",
    "description": "Tự động tìm kiếm trên Bing với từ khóa ngẫu nhiên vô nghĩa",
    "permissions": [
        "tabs",
        "storage",
        "scripting",
        "declarativeNetRequest",
        "browsingData",
        "cookies",
        "search",
        "alarms",
        "notifications",
        "privacy"
    ],
    "host_permissions": [
        "*://*.bing.com/*",
        "*://*.live.com/*",
        "*://*.microsoftonline.com/*",
        "*://*.microsoft.com/*",
        "*://*.msn.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
